const I18n = {
  lang: "pt",

  init() {
    const saved = localStorage.getItem("cv-lang");
    if (saved && TRANSLATIONS[saved]) this.lang = saved;
    this.apply();
    this.bindUI();
  },

  t(key) {
    return TRANSLATIONS[this.lang]?.[key] ?? TRANSLATIONS.pt[key] ?? key;
  },

  apply() {
    document.documentElement.lang =
      this.lang === "pt" ? "pt-BR" : this.lang === "gl" ? "gl" : this.lang;

    document.querySelectorAll("[data-i18n]").forEach((el) => {
      const key = el.dataset.i18n;
      const val = this.t(key);
      if (val) el.textContent = val;
    });

    const current = document.getElementById("lang-current");
    if (current) current.textContent = this.lang.toUpperCase();

    document.querySelectorAll("#lang-menu li").forEach((li) => {
      li.setAttribute("aria-selected", li.dataset.lang === this.lang ? "true" : "false");
    });

    window.dispatchEvent(new CustomEvent("langchange", { detail: { lang: this.lang } }));
  },

  setLang(code) {
    if (!TRANSLATIONS[code]) return;
    this.lang = code;
    localStorage.setItem("cv-lang", code);
    this.apply();
  },

  bindUI() {
    const toggle = document.getElementById("lang-toggle");
    const menu = document.getElementById("lang-menu");
    if (!toggle || !menu) return;

    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = menu.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", open);
    });

    menu.querySelectorAll("li").forEach((li) => {
      li.addEventListener("click", () => {
        this.setLang(li.dataset.lang);
        menu.classList.remove("is-open");
        toggle.setAttribute("aria-expanded", "false");
      });
    });

    document.addEventListener("click", () => {
      menu.classList.remove("is-open");
      toggle.setAttribute("aria-expanded", "false");
    });
  },
};

window.I18n = I18n;
